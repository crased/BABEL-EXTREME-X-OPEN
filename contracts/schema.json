{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lunartech.ai/babel-extreme-apprentice/schema.json",
  "title": "Babel-Extreme Apprentice Output",
  "type": "object",
  "required": ["source_file", "pages"],
  "additionalProperties": false,
  "properties": {
    "source_file": {
      "type": "string",
      "description": "Filename of the input the pipeline ran on. Basename only."
    },
    "source_lang_detected": {
      "type": ["string", "null"],
      "description": "ISO-639-1 code of the detected source language, or null if you did not detect."
    },
    "target_lang": {
      "type": ["string", "null"],
      "description": "ISO-639-1 code of the translation target language, or null if you did not translate."
    },
    "pages": {
      "type": "array",
      "items": { "$ref": "#/$defs/page" },
      "minItems": 1
    },
    "extraction_notes": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    }
  },
  "$defs": {
    "page": {
      "type": "object",
      "required": ["page_number", "width", "height", "elements", "reading_order"],
      "additionalProperties": false,
      "properties": {
        "page_number": { "type": "integer", "minimum": 1 },
        "width":  { "type": "integer", "minimum": 1, "description": "Page-image width in pixels." },
        "height": { "type": "integer", "minimum": 1, "description": "Page-image height in pixels." },
        "dpi_estimated": { "type": ["integer", "null"], "minimum": 1 },
        "elements": {
          "type": "array",
          "items": { "$ref": "#/$defs/element" }
        },
        "reading_order": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Element IDs in human reading order."
        }
      }
    },
    "element": {
      "type": "object",
      "required": ["id", "type", "bbox", "content", "confidence", "needs_review"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": {
          "type": "string",
          "enum": [
            "text_block", "heading", "caption", "table",
            "formula", "figure", "header", "footer", "list_item"
          ]
        },
        "bbox": { "$ref": "#/$defs/bbox" },
        "content": {
          "type": "string",
          "description": "Raw text. For formula, LaTeX. For figure, may be empty."
        },
        "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "needs_review": { "type": "boolean" },
        "translation": { "type": ["string", "null"] },
        "table": { "$ref": "#/$defs/table" },
        "figure_path": { "type": ["string", "null"] }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "table" } }, "required": ["type"] },
          "then": { "required": ["table"] }
        },
        {
          "if": { "properties": { "type": { "const": "figure" } }, "required": ["type"] },
          "then": {
            "required": ["figure_path"],
            "properties": {
              "figure_path": { "type": "string", "minLength": 1 }
            }
          }
        }
      ]
    },
    "bbox": {
      "type": "object",
      "required": ["x1", "y1", "x2", "y2"],
      "additionalProperties": false,
      "properties": {
        "x1": { "type": "number", "minimum": 0 },
        "y1": { "type": "number", "minimum": 0 },
        "x2": { "type": "number", "minimum": 0 },
        "y2": { "type": "number", "minimum": 0 }
      }
    },
    "table": {
      "type": "object",
      "required": ["rows", "cols", "cells"],
      "additionalProperties": false,
      "properties": {
        "rows": { "type": "integer", "minimum": 1 },
        "cols": { "type": "integer", "minimum": 1 },
        "cells": {
          "type": "array",
          "items": { "$ref": "#/$defs/cell" }
        }
      }
    },
    "cell": {
      "type": "object",
      "required": ["row", "col", "row_span", "col_span", "content", "is_header"],
      "additionalProperties": false,
      "properties": {
        "row": { "type": "integer", "minimum": 0 },
        "col": { "type": "integer", "minimum": 0 },
        "row_span": { "type": "integer", "minimum": 1 },
        "col_span": { "type": "integer", "minimum": 1 },
        "content": { "type": "string" },
        "is_header": { "type": "boolean" }
      }
    }
  }
}
